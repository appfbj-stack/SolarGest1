generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Cliente {
  id        String   @id @default(cuid())
  nome      String
  email     String?
  telefone  String?
  cidade    String?
  tipo      String   @default("Residencial")
  consumo   String?
  status    String   @default("Novo Lead")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tarefa {
  id        String   @id @default(cuid())
  conteudo  String
  valor     String   @default("R$ 0")
  dataTexto String   @default("Hoje")
  coluna    String   @default("Novo Lead")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Financeiro {
  id        String   @id @default(cuid())
  descricao String
  tipo      String
  valor     Decimal  @db.Decimal(10, 2)
  categoria String?
  data      DateTime @default(now())
  status    String   @default("Pendente")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Agenda {
  id        String   @id @default(cuid())
  titulo    String
  cliente   String?
  endereco  String?
  horario   String?
  equipe    String?
  tipo      String   @default("Instalação")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Equipamento {
  id       String  @id @default(cuid())
  codigo   String  @unique
  nome     String
  marca    String?
  tipo     String
  potencia String?
  estoque  Int     @default(0)
  preco    Decimal @db.Decimal(10, 2)
  status   String  @default("Em Estoque")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Projeto {
  id            String    @id @default(cuid())
  titulo        String
  cliente       String
  status        String    @default("Planejamento")
  potencia      String?
  endereco      String?
  dataInicio    DateTime?
  dataConclusao DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Orcamento {
  id          String   @id @default(cuid())
  numero      String   @unique
  cliente     String
  status      String   @default("Pendente")
  total       Decimal  @db.Decimal(10, 2)
  validade    DateTime?
  observacoes String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OrdemServico {
  id           String    @id @default(cuid())
  numero       String    @unique
  cliente      String
  tipo         String
  status       String    @default("Aberta")
  descricao    String?
  tecnico      String?
  dataAgendada DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
